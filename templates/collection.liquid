<div class="collection-header">
  <div class="site-inner">
    <p class="eyebrow">{{ collection.title }}</p>
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p style="margin-top:12px;color:var(--neutral-600);max-width:600px">{{ collection.description }}</p>
    {% endif %}
  </div>
</div>

<section class="section" style="background:var(--cream)">
  <div class="site-inner">
    {% if collection.products.size > 0 %}
      <div class="collection-grid">
        {% for product in collection.products %}
          <article class="product-card">
            <a href="{{ product.url }}">
              <div class="product-card__img">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '720x960' }}" alt="{{ product.title }}" loading="lazy" />
                {% else %}
                  <div class="gallery-fallback" style="background:linear-gradient(135deg,#6B1F3D,#3E2723)">💼</div>
                {% endif %}
              </div>
              <div class="product-card__body">
                <div class="product-card__name">{{ product.title }}</div>
                <div class="product-card__price">{{ product.price | money }}</div>
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p style="text-align:center;color:var(--neutral-500);padding:60px 0">No products found in this collection.</p>
    {% endif %}
  </div>
</section>
