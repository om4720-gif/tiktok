<!doctype html>
<html lang="{{ shop.locale }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="theme-color" content="#6B1F3D" />
  <title>{% if page_title %}{{ page_title }} – {% endif %}{{ shop.name }}</title>
  <meta name="description" content="{{ page_description | default: shop.description | escape }}" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&family=Dancing+Script:wght@500&display=swap" rel="stylesheet" />

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>

<body class="page-{{ template | split: '.' | first }}">

  <!-- Announcement Bar -->
  <div class="announcement-bar">
    <p>{{ settings.announcement_text | default: '✦ Free shipping on orders over 1,500 EGP  ·  Handcrafted luxury, made to order ✦' }}</p>
  </div>

  <!-- Header -->
  {% section 'header' %}

  <!-- Cart Drawer -->
  <div id="cart-overlay" class="cart-overlay" onclick="closeCart()"></div>
  <aside id="cart-drawer" class="cart-drawer" aria-label="Shopping cart">
    <div class="cart-drawer__header">
      <h2>Your Cart</h2>
      <button class="cart-close" onclick="closeCart()" aria-label="Close cart">✕</button>
    </div>
    <div id="cart-drawer__items" class="cart-drawer__items"></div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__total">
        <span>Total</span>
        <span id="cart-total">{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="button button-primary btn-full">Proceed to Checkout</a>
      <a href="/cart" class="button button-secondary btn-full" style="margin-top:10px;">View Full Cart</a>
    </div>
  </aside>

  <main role="main" id="main-content">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ 'theme.js' | asset_url | script_tag }}
  {{ content_for_footer }}
</body>
</html>
